{
  "expo": {
    "name": "RendeMais",
    "slug": "rende-mais",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo1greenbg.png",
    "scheme": "rende-mais",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/logo1greenbg.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rendemais.app"
    },
    "android": {
      "package": "com.rendemais.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoappforeground.png",
        "backgroundColor": "#16a34a"
      }
    },
    "web": {
      "favicon": "./assets/images/logo1greenbg.png"
    },
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-3776982600781310~1770021128"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "react-native-google-mobile-ads"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "9ac23cf9-5947-4d08-90eb-caafc753713f"
      }
    }
  }
}
