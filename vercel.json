{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/rende-mais build:web",
  "outputDirectory": "artifacts/rende-mais/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!_expo/|assets/|favicon.ico|robots.txt|sitemap.xml|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
